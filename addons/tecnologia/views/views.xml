<odoo>
  <data>
    <record id="action_workstation" model="ir.actions.act_window">
      <field name="name"> Estaciones de trabajo </field>
      <field name="res_model">tecnologia.workstation</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- List View -->
    <record id="view_workstation_list=" model="ir.ui.view">
      <field name="name">tecnologia.workstation.list</field>
      <field name="model">tecnologia.workstation</field>
      <field name="arch" type="xml">
        <list>
          <field name="name" />
          <field name="model" />
        </list>
      </field>
    </record>

    <!-- Form View -->
    <record id="view_workstation_form" model="ir.ui.view">
      <field name="name">tecnologia.workstation.form</field>
      <field name="model">tecnologia.workstation</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name" />
              <field name="model" />
            </group>
          </sheet>
        </form>
      </field>
    </record>

  </data>
</odoo>