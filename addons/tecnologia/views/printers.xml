<odoo>
    <data>
        <record id="action_printers" model="ir.actions.act_window">
            <field name="name"> Impresoras </field>
            <field name="res_model">tecnologia.printers</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- List View -->
        <record id="view_printers_list=" model="ir.ui.view">
            <field name="name">tecnologia.printers.list</field>
            <field name="model">tecnologia.printers</field>
            <field name="arch" type="xml">
                <list>
                    <field name="location" />
                    <field name="manufacturer" />
                    <field name="model" />
                    <field name="serial" />
                    <field name="rented" />
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_printers_form" model="ir.ui.view">
            <field name="name">tecnologia.printers.form</field>
            <field name="model">tecnologia.printers</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>

                            <group>
                                <separator string="Datos Técnicos" />

                                <field name="manufacturer" />
                                <field name="model" />
                                <field name="serial" />
                                <field name="rented" />
                            </group>

                            <group>
                                <separator string="Ubicación" />

                                <field name="location" />
                            </group>


                            <group>
                                <separator string="Red" />

                                <field name="mac_address" />
                                <field name="ip_address" />
                            </group>

                            <group>
                                <separator string="Rastreo" />

                                <field name="antiquity" />
                                <field name="date_assigned" />
                                <field name="date_checked" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>